terraform {
  required_version = ">= 1.6.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.20"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}

provider "azurerm" {
  features {}
  # subscription_id is read from the ARM_SUBSCRIPTION_ID env var (deploy.sh
  # sets it from `az account show`). Pin one here if you prefer.
}
